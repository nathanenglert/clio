{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clio",
  "version": "0.2.0",
  "identifier": "com.dbapp.poc",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Clio",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 480,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/nathanenglert/clio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU3NkIyQjk2NTU3REZCMzEKUldReCszMVZsaXRyNStjYWtmQlpTQ3JERTZOTWdOOGJNTHdtZUZMMmdFa1k2eGFDbE85T1BwbjcK"
    }
  }
}
